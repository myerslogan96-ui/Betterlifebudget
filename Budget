function mk(){const n=new Date();return`${n.getFullYear()}-${n.getMonth()+1}`}
function mlabel(k){const[y,m]=k.split("-").map(Number);return new Date(y,m-1,1).toLocaleString("default",{month:"long",year:"numeric"})}
function fc(n){return`$${Math.abs(n).toFixed(2)}`}
function dLeft(){const n=new Date();return new Date(n.getFullYear(),n.getMonth()+1,0).getDate()-n.getDate()}
function ld(k,d){try{const v=localStorage.getItem(k);return v?JSON.parse(v):d}catch(e){return d}}
function sv(k,v){try{localStorage.setItem(k,JSON.stringify(v))}catch(e){}}

