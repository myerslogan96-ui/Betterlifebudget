function showToast(msg){setToast(msg);setTimeout(()=>setToast(null),2500)}
function addTxn(){
if(!form.amount||isNaN(parseFloat(form.amount)))return;
const t={id:Date.now(),amount:parseFloat(form.amount),category:form.category,note:form.note,date:form.date};
const u={…txns,[m]:[t,…(txns[m]||[])]};setTxns(u);sv(“lb-txns”,u);
setForm({…form,amount:””,note:””});showToast(“Added ✓”);
}
function delTxn(id){
const u={…txns,[m]:(txns[m]||[]).filter(t=>t.id!==id)};setTxns(u);sv(“lb-txns”,u);showToast(“Deleted”);
}
function closeMonth(){
const saved=Math.max(TOTAL-totalSpent,0);
const ns={…savings,[m]:saved};setSavings(ns);sv(“lb-savings”,ns);
setModal(false);showToast(`Saved ${fc(saved)} this month 🎉`);
}

