const projSav=Math.max(TOTAL-totalSpent,0);
const allSaved=Object.entries(savings).sort((a,b)=>a[0].localeCompare(b[0]));
const totalSaved=allSaved.reduce((s,[,v])=>s+v,0);
const efPct=Math.min((totalSaved/EFGOAL)*100,100);
